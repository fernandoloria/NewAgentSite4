<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Report.master.cs" Inherits="AgentSite4.Master.Report" %>

<%@ Register TagPrefix="Crl" TagName="Balances" Src="~/Controls/Classic/WelcomeForm.ascx" %>
<%@ Register TagPrefix="Crl" TagName="MenuButton" Src="~/Controls/Classic/MenuButton.ascx" %>
<%@ Register TagPrefix="Crl" TagName="SideBarTickets" Src="~/Controls/Classic/SideBarTickets.ascx" %>
<%@ Register TagPrefix="Crl" TagName="Header" Src="~/Controls/Classic/Header.ascx" %>


<!DOCTYPE html>
<html lang="en">

<head runat="server">
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, shrink-to-fit=no">
    <title><%= Page.Title %></title>

    <link rel="icon" type="image/x-icon" href="/src/assets/img/favicon.svg" />
    <link href="/src/layouts/vertical-light-menu/css/light/loader.css" rel="stylesheet" type="text/css" />
    <link href="/src/layouts/vertical-light-menu/css/dark/loader.css" rel="stylesheet" type="text/css" />
    <script src="/src/layouts/vertical-light-menu/loader.js?v=123"></script>

    <!-- BEGIN GLOBAL MANDATORY STYLES -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:400,600,700" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">

    <link href="/src/layouts/vertical-light-menu/css/light/plugins.css?v=132" rel="stylesheet" type="text/css" />
    <link href="/src/layouts/vertical-light-menu/css/dark/plugins.css?v=130" rel="stylesheet" type="text/css" />
    <link href="/src/fontawesome/css/fontawesome.css?v=123" rel="stylesheet">
    <link href="/src/fontawesome/css/all.css?v=123" rel="stylesheet">
    <!-- END GLOBAL MANDATORY STYLES -->

    <!-- BEGIN PAGE LEVEL PLUGINS/CUSTOM STYLES -->
    <link href="/src/plugins/src/apex/apexcharts.css" rel="stylesheet" type="text/css">
    <link href="/src/assets/css/light/dashboard/dash_1.css" rel="stylesheet" type="text/css" />
    <link href="/src/assets/css/dark/dashboard/dash_1.css" rel="stylesheet" type="text/css" />
    <!-- END PAGE LEVEL PLUGINS/CUSTOM STYLES -->

    <link href="/src/plugins/src/flatpickr/flatpickr.css" rel="stylesheet" type="text/css">
    <link href="/src/plugins/src/noUiSlider/nouislider.min.css" rel="stylesheet" type="text/css">
    <link href="/src/assets/css/dark/scrollspyNav.css" rel="stylesheet" type="text/css" />
    <link href="/src/plugins/css/dark/flatpickr/custom-flatpickr.css" rel="stylesheet" type="text/css">

    <link rel="stylesheet" type="text/css" href="/src/plugins/src/tomSelect/tom-select.default.min.css">
    <link rel="stylesheet" type="text/css" href="/src/plugins/css/light/tomSelect/custom-tomSelect.css">
    <link rel="stylesheet" type="text/css" href="/src/plugins/css/dark/tomSelect/custom-tomSelect.css">

    <link href="/src/assets/css/light/scrollspyNav.css" rel="stylesheet" type="text/css">
    <link rel="stylesheet" type="text/css" href="/src/assets/css/light/forms/switches.css">

    <link href="/src/assets/css/dark/scrollspyNav.css" rel="stylesheet" type="text/css">
    <link rel="stylesheet" type="text/css" href="/src/assets/css/dark/forms/switches.css">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
    <link href="/src/assets/css/global-styles.css?v=19asasasdas28s" rel="stylesheet" />
   
    
    <style>
        


    </style>


    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>
</head>
<body class="layout-boxed">
    <div id="loading"></div>
    <div id="load_screen">
        <div class="loader">
            <div class="loader-content">
                <div class="spinner-grow align-self-center"></div>
            </div>
        </div>
    </div>
    <!--  END LOADER -->
    <form id="form1" runat="server">
        <!-- BEGIN LOADER -->


        <!--  BEGIN NAVBAR  -->
        <div class="header-container container-xxl">
            <header class="header navbar navbar-expand-sm expand-header">
                <Crl:Header runat="server" ID="Header" />
            </header>
        </div>
        <!--  END NAVBAR  -->

        <!--  BEGIN MAIN CONTAINER  -->
        <div class="main-container" id="container">
            <div class="secondary-nav">
                <div class="breadcrumbs-container" data-page-heading="Analytics">
                    <header class="header navbar navbar-expand-sm">
                        <a href="javascript:void(0);" class="btn-toggle sidebarCollapse" data-placement="bottom">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-menu">
                                <line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                        </a>
                    </header>
                </div>
            </div>

            <div class="overlay"></div>
            <div class="search-overlay"></div>

            <!--  BEGIN SIDEBAR  -->
            <div class="sidebar-wrapper sidebar-theme">

                <Crl:MenuButton runat="server" ID="MenuButton" />

            </div>
            <!--  END SIDEBAR  -->

            <!--  BEGIN CONTENT AREA  -->
            <div id="content" class="main-content">

                <asp:ContentPlaceHolder ID="MainContent" runat="server">
                </asp:ContentPlaceHolder>
                <!--  BEGIN FOOTER  -->
                <div class="footer-wrapper">
                    <div class="footer-section f-section-1">
                        <p class="">Copyright &copy; <%=DateTime.Now.Year %> Agent Admin</p>
                    </div>

                </div>
                <!--  END FOOTER  -->
            </div>
            <!--  END CONTENT AREA  -->

        </div>
        <!-- END MAIN CONTAINER -->


        <div class="modal fullscreen-modal" id="PopUpModal" tabindex="-1" role="dialog" aria-labelledby="PopUpModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-body">
                    </div>
                </div>
            </div>
        </div>


    </form>

    <!-- BEGIN GLOBAL MANDATORY SCRIPTS -->
    <script src="/src/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/src/plugins/src/perfect-scrollbar/perfect-scrollbar.min.js"></script>
    <script src="/src/plugins/src/mousetrap/mousetrap.min.js"></script>
    <script src="/src/plugins/src/waves/waves.min.js"></script>
    <script src="/src/layouts/vertical-light-menu/app.js?v1"></script>
    <script src="/src/plugins/src/highlight/highlight.pack.js"></script>
    <!-- END GLOBAL MANDATORY SCRIPTS -->

    <!-- BEGIN PAGE LEVEL PLUGINS/CUSTOM SCRIPTS -->
    <script src="/src/plugins/src/apex/apexcharts.min.js"></script>
    <script src="/src/assets/js/dashboard/dash_1.js?v=9"></script>
    <!-- BEGIN PAGE LEVEL PLUGINS/CUSTOM SCRIPTS -->

   <%-- <script src="/src/js/functions.js?v=12"></script>--%>
    <% ="<script src='/src/js/functions.js?v="+ rnd.Next() +"' ></script>" %>


    <script src="/src/plugins/src/flatpickr/flatpickr.js"></script>
    <script src="/src/plugins/src/flatpickr/custom-flatpickr.js?v=3"></script>

    <script src="/src/assets/js/scrollspyNav.js?v2"></script>
    <script src="/src/plugins/src/tomSelect/tom-select.base.js"></script>
    <script src="/src/plugins/src/tomSelect/custom-tom-select.js?v=1"></script>
    
    <script src="/src/js/app-core.js?v=14"></script>
    <script src="/src/js/searchbar.js?v=12"></script>
    
    <script type="text/javascript">
       
    </script>

    <asp:ContentPlaceHolder ID="Footer" runat="server">
    </asp:ContentPlaceHolder>

    <asp:ContentPlaceHolder ID="scripts" runat="server">
    </asp:ContentPlaceHolder>
</body>

</html>
